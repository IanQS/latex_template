%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Essay style: simple long-form layout with running headers and a bibliography.
% Pairs with essay.tex.  Expects these commands in the main file:
%   \essayTitle \essayAuthor \essayDate  (and optionally \essaySubtitle)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{essaystyle}[2026/06/04 Essay style]

\RequirePackage{preamble}
\RequirePackage{setspace}            % \onehalfspacing / \doublespacing if wanted
\RequirePackage{csquotes}            % Context-sensitive quotes (load before biblatex)
\RequirePackage[backend=biber,style=phys,sorting=none,articletitle=true]{biblatex}
\addbibresource{references.bib}      % Your .bib file

% Nature-style \textcite: keep the auto-generated author names ("Cook et al.") but
% render the number as a SUPERSCRIPT ("Cook et al.²") instead of numeric-comp's
% default bracketed "Cook et al. [2]". This makes \textcite match \autocite so the
% whole document is uniformly superscript. (Single key is the common case; multiple
% keys for the SAME author are not compressed -- use \autocite{a,b} for that.)
\DeclareCiteCommand{\textcite}
  {}%
  {\usebibmacro{citeindex}%
   \ifnameundef{labelname}
     {\printfield[citetitle]{labeltitle}}
     {\printnames{labelname}}%
   \mkbibsuperscript{\printtext[bibhyperref]{\printfield{labelprefix}\printfield{labelnumber}}}}%
  {\multicitedelim}%
  {}

% Safety net: make plain \cite superscript too (alias to \autocite) so an old-habit
% \cite{} can't reintroduce bracketed "[1]". \autocite/\parencite/\textcite keep
% their own meanings; only bare \cite changes.
\let\cite\autocite

% Uncomment for wider line spacing (common for submitted essays):
%\onehalfspacing

%----------------------------------------------------------------------------------------
%	HEADERS AND FOOTERS
%----------------------------------------------------------------------------------------
\pagestyle{fancy}
\lhead{\small\essayAuthor}
\chead{}
\rhead{\small\itshape\essayTitle}
\lfoot{}
\cfoot{\small\thepage}
\rfoot{}
\renewcommand\headrulewidth{0.5pt}

%----------------------------------------------------------------------------------------
%	TITLE
%----------------------------------------------------------------------------------------
\title{
	\textbf{\essayTitle}%
	\ifdef{\essaySubtitle}{\ifdefempty{\essaySubtitle}{}{\\[4pt]{\large\itshape \essaySubtitle}}}{}
}
\author{\essayAuthor}
\date{\essayDate}

\endinput
